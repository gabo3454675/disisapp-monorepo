{
  "name": "@billing-system/disis-monolith",
  "version": "1.0.0",
  "private": true,
  "description": "Modulo monolitico DISIS para auth, billing, dispatch y clients",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema ../server/prisma/schema.prisma",
    "prisma:migrate": "echo \"Las migraciones viven en apps/server; ejecuta: cd ../server && pnpm prisma migrate dev\"",
    "prisma:studio": "prisma studio --schema ../server/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.10.0",
    "express": "^5.1.0",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.3",
    "@types/speakeasy": "^2.0.10",
    "prisma": "5.10.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
