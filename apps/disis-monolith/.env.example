# =============================================================================
# DISIS Monolith Module - Variables de entorno
# Usa la MISMA base de datos PostgreSQL de DISIS (no crear otra DB aparte).
# =============================================================================

# PostgreSQL compartida de DISIS
DATABASE_URL="postgresql://user:password@localhost:5432/disis_db?schema=public"

# Puerto del modulo disis-monolith
PORT=4100

# URL del backend Nest (apps/server), prefijo global /api — para registrar InventoryMovement tras despacho
DISIS_SERVER_URL="http://localhost:3001/api"

# Misma cadena que DISIS_DISPATCH_SHARED_SECRET en apps/server/.env (cabecera x-disis-dispatch-secret)
DISIS_DISPATCH_SHARED_SECRET=""

# Entorno
NODE_ENV=development
