# =============================================================================
# Frontend (Next.js) - Variables de entorno
# Copiar a .env.local y completar los valores antes de levantar el client.
# =============================================================================

# -----------------------------------------------------------------------------
# API (obligatorio para producción)
# -----------------------------------------------------------------------------
# URL base del API (backend). En desarrollo suele ser http://localhost:3001/api
# Debe incluir el prefijo /api. En producción usar la URL real del backend.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# -----------------------------------------------------------------------------
# Nota
# -----------------------------------------------------------------------------
# NODE_ENV lo define Next.js automáticamente (development | production).
# Solo las variables con prefijo NEXT_PUBLIC_ están disponibles en el navegador.
